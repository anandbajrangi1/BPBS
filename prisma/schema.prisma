// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id            String        @id @default(cuid())
  name          String?
  username      String?       @unique
  password      String?
  phone         String?       @unique
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  role          Role          @default(USER)
  status        Status        @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  donations     Donation[]
  japaSessions  JapaSession[]
  enrollments   CourseEnrollment[]
  notifications Notification[]
  lessonProgress LessonProgress[]
  sevaVolunteering SevaVolunteer[]
  sadhnaReports SadhnaReport[]
  eventRSVPs    EventRSVP[]
  accounts      Account[]
  sessions      Session[]
}

// NextAuth required models
// ... (omitting for brevity in this tool call replaced sections)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpToken {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  image       String?
  date        DateTime
  venue       String
  location    String
  description String   @db.Text
  category    String   @default("Festival")
  rsvp        Boolean  @default(true)
  attendees   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rsvps       EventRSVP[]
}

model EventRSVP {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  instructor  String
  duration    String
  level       String   @default("Beginner")
  enrolled    Int      @default(0)
  rating      Float    @default(5.0)
  description String   @db.Text
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  enrollments CourseEnrollment[]
  lessons     Lesson[]
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  videoUrl    String?
  content     String?  @db.Text // Markdown for lesson text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  progress    LessonProgress[]
}

model CourseEnrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@unique([userId, lessonId])
}

model Kirtan {
  id        String   @id @default(cuid())
  title     String
  artist    String
  duration  String
  type      String   @default("kirtan") // kirtan | bhajan | stotra
  category  String?
  plays     Int      @default(0)
  url       String? // S3/CDN URL
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SevaOpportunity {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  date        String
  location    String
  emoji       String   @default("🙏")
  color       String   @default("#FFB38E")
  createdAt   DateTime @default(now())
  volunteers  SevaVolunteer[]
}

model SevaVolunteer {
  id                String          @id @default(cuid())
  userId            String
  sevaOpportunityId String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sevaOpportunity   SevaOpportunity @relation(fields: [sevaOpportunityId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())

  @@unique([userId, sevaOpportunityId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  seen      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Slide {
  id       String  @id @default(cuid())
  title    String
  subtitle String?
  image    String?
  link     String?
  color    String  @default("#FFB38E")
  order    Int     @default(0)
}

model Donation {
  id                String         @id @default(cuid())
  userId            String?
  user              User?          @relation(fields: [userId], references: [id])
  amount            Int            // in paise (100 paise = ₹1)
  purpose           String
  method            String         @default("Razorpay")
  razorpayOrderId   String?        @unique
  razorpayPaymentId String?
  razorpaySignature String?
  status            DonationStatus @default(PENDING)
  donorName         String?
  donorPhone        String?
  createdAt         DateTime       @default(now())
}

model JapaSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rounds    Int      @default(0)
  duration  Int      @default(0) // seconds
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model SadhnaReport {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime @default(now())
  sleepTime    String?  // e.g., "10:00 PM"
  wakeUpTime   String?  // e.g., "04:00 AM"
  rounds       Int      @default(0)
  readingHours Float    @default(0)
  hearingHours Float    @default(0)
  remarks      String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
